# Required for iron-session (generate a long random string)
SESSION_SECRET=

# Optional: separate HMAC key for signed “section-only” share links (defaults to SESSION_SECRET if unset)
PRODUCT_SHARE_SECRET=

# Primary demo user (existing flow — unchanged)
AUTH_USERNAME=
# bcrypt hash: use base64 of the bcrypt string (recommended) or a quoted plain $2b$... string
AUTH_PASSWORD_HASH=

# Optional: second user who must choose a commissioning entity before the store (e.g. luda / cris)
# Generate base64 hash: node -e "const b=require('bcryptjs');const h=b.hashSync('YOUR_PASSWORD',10);console.log(Buffer.from(h,'utf8').toString('base64'))"
AUTH_MULTI_USERNAME=
AUTH_MULTI_PASSWORD_HASH=
